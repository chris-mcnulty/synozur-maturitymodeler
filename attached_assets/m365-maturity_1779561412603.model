        "minScore": 100,
        "maxScore": 199
      },
      {
        "id": "2",
        "name": "Managed",
        "description": "Key processes defined but not consistently applied",
        "minScore": 200,
        "maxScore": 299
      },
      {
        "id": "3",
        "name": "Defined",
        "description": "Standardized, signed-off processes with organization-wide adoption",
        "minScore": 300,
