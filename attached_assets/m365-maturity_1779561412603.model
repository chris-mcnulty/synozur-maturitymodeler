    {
      "dimensionKey": "collaboration",
      "text": "How does your organization manage the creation and lifecycle of Microsoft Teams workspaces?",
      "type": "multiple_choice",
      "order": 0,
      "minValue": null,
      "maxValue": null,
      "unit": null,
      "placeholder": null,
      "improvementStatement": null,
      "resourceTitle": null,
      "resourceLink": null,
      "resourceDescription": null,
      "answers": [
        {
          "text": "Teams are created ad hoc by anyone with no naming conventions, ownership requirements, or governance policies",
          "score": 100,
          "order": 0,
          "improvementStatement": null,
          "resourceTitle": null,
          "resourceLink": null,
          "resourceDescription": null
        },
        {
          "text": "Informal guidelines exist but Teams proliferation and inactive workspaces are common issues",
          "score": 200,
          "order": 1,
          "improvementStatement": null,
          "resourceTitle": null,
          "resourceLink": null,
          "resourceDescription": null
        },
        {
          "text": "A provisioning policy exists with naming conventions, ownership requirements, and template-based creation",
          "score": 300,
          "order": 2,
          "improvementStatement": null,
          "resourceTitle": null,
          "resourceLink": null,
          "resourceDescription": null
        },
        {
          "text": "Teams lifecycle is actively managed — inactive workspaces are reviewed and archived or deleted based on measured criteria",
          "score": 400,
          "order": 3,
          "improvementStatement": null,
          "resourceTitle": null,
          "resourceLink": null,
          "resourceDescription": null
        },
        {
          "text": "Teams governance is fully automated with provisioning workflows, ownership enforcement, and lifecycle policies continuously optimized through usage analytics",
          "score": 500,
          "order": 4,
          "improvementStatement": null,
          "resourceTitle": null,
          "resourceLink": null,
          "resourceDescription": null
        }
      ]
    },
